# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# uv / virtualenv
.venv/
backend/.venv/

# Env files (contain secrets)
.env
.env.local
.env.*.local
backend/.env
backend/.env.local

# Node / frontend
node_modules/
frontend/dist/
frontend/.vite/

# OS
.DS_Store

# Editor
.idea/
.vscode/
*.swp

# Work-local artifacts (not version-controlled)
_bmad-output/
design/

# Source recordings for the README demo videos. Only the converted
# .mp4 deliverables ship in the repo; .mov masters stay local.
docs/screenshots/*.mov
# Most of .claude/ is local-only state (settings.local.json, per-machine
# checkpoint scratchpads under docs/). Skills are project-shared tooling
# — re-include just that subtree so contributors pick up /update,
# /migrate, etc. on clone. Note: ignore the children with `.claude/*`,
# not the directory itself — git refuses to re-include a path whose
# parent dir was excluded as a unit.
.claude/*
!.claude/skills/
!.claude/skills/**